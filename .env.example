# 复制这个文件为 .env，然后填入你的 API Key
# cp .env.example .env

# ── 必填 ──────────────────────────────────────────
OPENAI_API_KEY=sk-xxx

# ── LLM 配置 ──────────────────────────────────────
# 可选：自定义模型（默认 gpt-4o-mini）
# OPENAI_MODEL=deepseek-chat

# 可选：自定义 API 地址（国内 API 用）
# OPENAI_BASE_URL=https://api.deepseek.com

# 可选：LLM 调用超时秒数（默认 30）
# LLM_TIMEOUT=30

# 可选：LLM 调用最大重试次数（默认 3）
# LLM_MAX_RETRIES=3

# ── 安全配置 ──────────────────────────────────────
# 用户输入最大字符数（默认 2000）
# MAX_INPUT_LENGTH=2000

# 单轮同一工具最大调用次数（默认 5）
# MAX_TOOL_CALLS_PER_TURN=5

# 总工具调用次数上限（默认 15）
# MAX_TOOL_CALLS_TOTAL=15

# 是否启用 prompt 注入检测（默认 true）
# ENABLE_INJECTION_CHECK=true

# ── Agent 配置 ────────────────────────────────────
# ReAct 循环最大步数（默认 5）
# MAX_STEPS=5

# 短期记忆最大条数（默认 30）
# MAX_MEMORY=30

# ── 调试 ──────────────────────────────────────────
# 开启调试模式，控制台显示详细日志（默认 false）
# DEBUG=true
